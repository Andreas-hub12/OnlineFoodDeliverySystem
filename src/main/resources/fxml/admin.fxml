<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="800.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.onlinefooddeliverysystem.controller.AdminController">
   <top>
      <HBox styleClass="header-bar" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="header-title" text="Admin Control Dashboard" />
         </children>
      </HBox>
   </top>
   <center>
      <StackPane BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER" maxWidth="450.0" spacing="18.0" styleClass="card-container">
               <children>
                  <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2D3748;" text="Management Actions" />
                  <Button maxWidth="1.1796493437496016E308" mnemonicParsing="false" onAction="#handleManageFood" styleClass="button-primary" text="Manage Food Items" />
                  <Button maxWidth="1.1796493437496016E308" mnemonicParsing="false" styleClass="button-secondary" text="Manage Orders" />
                  <Button maxWidth="1.1796493437496016E308" mnemonicParsing="false" onAction="#handleLogout" styleClass="button-danger" text="Logout" />
               </children>
               <padding>
                  <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
               </padding>
            </VBox>
         </children>
      </StackPane>
   </center>
</BorderPane>