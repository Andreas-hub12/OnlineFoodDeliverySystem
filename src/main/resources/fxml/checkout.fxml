<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="800.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.onlinefooddeliverysystem.controller.CheckoutController">
   <top>
      <HBox styleClass="header-bar" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="header-title" text="Checkout &amp; Payment" />
         </children>
      </HBox>
   </top>
   <center>
      <VBox spacing="15.0" BorderPane.alignment="CENTER">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #4A5568;" text="Delivery Address" />
                  <TextField fx:id="txtAddress" promptText="Enter delivery address" />
               </children>
            </VBox>
            <VBox spacing="5.0">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #4A5568;" text="Payment Method" />
                  <ChoiceBox fx:id="cmbPayment" maxWidth="1.1796493437496016E308" />
               </children>
            </VBox>
            <VBox spacing="5.0" VBox.vgrow="ALWAYS">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #4A5568;" text="Order Summary" />
                  <ListView fx:id="listOrderSummary" prefHeight="150.0" VBox.vgrow="ALWAYS" />
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </center>
   <bottom>
      <HBox alignment="CENTER" spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="lblTotal" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2D3748;" text="Total: $0.00" />
            <HBox alignment="CENTER_RIGHT" spacing="15.0" HBox.hgrow="ALWAYS">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleBack" styleClass="button-secondary" text="Back" />
                  <Button mnemonicParsing="false" onAction="#handleConfirmOrder" styleClass="button-primary" text="Confirm Order" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>