<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="500.0" prefWidth="700.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.onlinefooddeliverysystem.controller.RegisterController">
   <children>
      <VBox alignment="CENTER" maxWidth="400.0" spacing="20.0" styleClass="card-container">
         <children>
            <VBox alignment="CENTER" spacing="5.0">
               <children>
                  <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2D3748;" text="Create an Account" />
                  <Label style="-fx-font-size: 13px; -fx-text-fill: #718096;" text="Join us and start ordering delicious food!" />
               </children>
            </VBox>

            <VBox spacing="12.0">
               <children>
                  <VBox spacing="4.0">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #4A5568;" text="Username" />
                        <TextField fx:id="txtUsername" promptText="Choose a username" />
                     </children>
                  </VBox>
                  <VBox spacing="4.0">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #4A5568;" text="Password" />
                        <PasswordField fx:id="txtPassword" promptText="Choose a password" />
                     </children>
                  </VBox>
               </children>
            </VBox>

            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleBackToLogin" prefWidth="150.0" styleClass="button-secondary" text="Back" />
                  <Button mnemonicParsing="false" onAction="#handleRegisterUser" prefWidth="150.0" styleClass="button-primary" text="Register" />
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </HBox>
         </children>
         <padding>
            <Insets bottom="35.0" left="35.0" right="35.0" top="35.0" />
         </padding>
      </VBox>
   </children>
</StackPane>