<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="800.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.onlinefooddeliverysystem.controller.MenuController">
   <top>
      <HBox styleClass="header-bar" BorderPane.alignment="CENTER">
         <children>
            <VBox>
               <children>
                  <!-- Bound fx:id="lblRestaurantName" -->
                  <Label fx:id="lblRestaurantName" styleClass="header-title" text="Restaurant Name" />
                  <Label styleClass="header-subtitle" text="Explore Menu &amp; Select Items" />
               </children>
            </VBox>
         </children>
      </HBox>
   </top>
   <center>

      <TableView fx:id="tableMenu" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <columns>

            <TableColumn fx:id="colName" prefWidth="550.0" text="Food Item" />
            <TableColumn fx:id="colPrice" prefWidth="180.0" text="Price ($)" />
         </columns>
         <BorderPane.margin>
            <Insets bottom="15.0" left="20.0" right="20.0" top="20.0" />
         </BorderPane.margin>
      </TableView>
   </center>
   <bottom>
      <HBox alignment="CENTER_RIGHT" spacing="15.0" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" onAction="#handleBack" styleClass="button-secondary" text="Back" />
            <Button mnemonicParsing="false" onAction="#handleViewCart" styleClass="button-secondary" text="View Cart" />

            <Button mnemonicParsing="false" onAction="#handleAddToCart" styleClass="button-primary" text="Add to Cart" />
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="5.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>