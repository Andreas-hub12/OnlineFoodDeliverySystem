<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="800.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.onlinefooddeliverysystem.controller.CartController">
   <top>
      <HBox styleClass="header-bar" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="header-title" text="Your Shopping Cart" />
         </children>
      </HBox>
   </top>
   <center>
      <VBox spacing="10.0" BorderPane.alignment="CENTER">
         <children>

            <TableView fx:id="tableCart" prefHeight="380.0" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colName" prefWidth="300.0" text="Food Item" />
                  <TableColumn fx:id="colPrice" prefWidth="150.0" text="Price ($)" />
                  <TableColumn fx:id="colCategory" prefWidth="250.0" text="Category" />
               </columns>
            </TableView>
         </children>
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </center>
   <bottom>
      <HBox alignment="CENTER" spacing="20.0" BorderPane.alignment="CENTER">
         <children>

            <Label fx:id="lblTotal" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2D3748;" text="Total: $0.00" />
            <HBox alignment="CENTER_RIGHT" spacing="15.0" HBox.hgrow="ALWAYS">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleRemove" styleClass="button-danger" text="Remove Selected" />
                  <Button mnemonicParsing="false" onAction="#handleBack" styleClass="button-secondary" text="Back" />
                  <Button mnemonicParsing="false" onAction="#handleCheckout" styleClass="button-primary" text="Proceed to Checkout" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>