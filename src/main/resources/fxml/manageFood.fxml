<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650.0" prefWidth="800.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.onlinefooddeliverysystem.controller.ManageFoodController">
    <top>
        <HBox styleClass="header-bar" BorderPane.alignment="CENTER">
            <children>
                <Label styleClass="header-title" text="Manage Food Items" />
            </children>
        </HBox>
    </top>
    <center>
        <VBox spacing="15.0" BorderPane.alignment="CENTER">
            <children>
                <TableView fx:id="tableFood" prefHeight="250.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colName" prefWidth="200.0" text="Food Name" />
                        <TableColumn fx:id="colPrice" prefWidth="120.0" text="Price ($)" />
                        <TableColumn fx:id="colCategory" prefWidth="200.0" text="Category" />
                        <TableColumn fx:id="colRestaurant" prefWidth="200.0" text="Restaurant" />
                    </columns>
                </TableView>

                <VBox spacing="10.0" styleClass="card-container">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #2D3748;" text="Item Details" />
                        <TextField fx:id="txtName" promptText="Food Name" />
                        <HBox spacing="10.0">
                            <children>
                                <TextField fx:id="txtPrice" promptText="Price ($)" HBox.hgrow="ALWAYS" />
                                <TextField fx:id="txtCategory" promptText="Category" HBox.hgrow="ALWAYS" />

                                <ComboBox fx:id="cmbRestaurant" promptText="Select Restaurant" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleAdd" styleClass="button-primary" text="Add" />
                                <Button mnemonicParsing="false" onAction="#handleUpdate" styleClass="button-secondary" text="Update" />
                                <Button mnemonicParsing="false" onAction="#handleDelete" styleClass="button-danger" text="Delete" />
                                <Button mnemonicParsing="false" onAction="#handleRefresh" styleClass="button-secondary" text="Refresh" />
                            </children>
                            <VBox.margin>
                                <Insets top="5.0" />
                            </VBox.margin>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                </VBox>
            </children>
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="15.0" />
            </padding>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" BorderPane.alignment="CENTER">
            <children>
                <Button mnemonicParsing="false" onAction="#handleBack" styleClass="button-secondary" text="Back to Admin" />
            </children>
            <padding>
                <Insets bottom="15.0" left="20.0" right="20.0" top="5.0" />
            </padding>
        </HBox>
    </bottom>
</BorderPane>